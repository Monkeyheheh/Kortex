# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BIND_HOST=127.0.0.1

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ed679645bb15620c7acd3a8c859a4ff58c607856c2910136dba9fa9ed296878b7aeed99ff644687c8decb528a89a3fd67e771cd99285f63097495b5d623621fa

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Messaging ────────────────────────────────────────────────────────────────
MSG_MAX_LENGTH=4000
MAX_MSG_LIMIT=200

# ─── Validation ───────────────────────────────────────────────────────────────
USERNAME_MIN_LENGTH=3
USERNAME_MAX_LENGTH=32
PASSWORD_MIN_LENGTH=8

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REGISTER_WINDOW_MS=60000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_MESSAGES_WINDOW_MS=10000
RATE_LIMIT_MESSAGES_MAX=30
RATE_LIMIT_CONTACTS_WINDOW_MS=60000
RATE_LIMIT_CONTACTS_MAX=20

# ─── Socket.IO ────────────────────────────────────────────────────────────────
SOCKET_PING_TIMEOUT_MS=30000
SOCKET_PING_INTERVAL_MS=15000

# ─── Persistence ──────────────────────────────────────────────────────────────
DATA_FILE=./data.json
SAVE_DEBOUNCE_MS=200

# ─── Static files ─────────────────────────────────────────────────────────────
PUBLIC_DIR=src

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Proxy ────────────────────────────────────────────────────────────────────
TRUSTED_PROXY=1